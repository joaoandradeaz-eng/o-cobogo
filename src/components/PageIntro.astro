---
/**
 * Page intro: tagline-strip (todas as páginas) + parede de cobogós Grade
 * com sombra do Congresso (SÓ na home).
 *
 * Em /sobre e /[slug] a tagline ganha mais espaço (modificador .no-wall)
 * já que vira a única peça visual entre header e conteúdo.
 *
 * No mobile a parede está sempre oculta (display:none via media query) —
 * a regra .no-wall do desktop não interfere lá.
 */
const isHome = Astro.url.pathname === '/';
---

<!-- Tagline strip — sempre visível -->
<div class:list={['tagline-strip', !isHome && 'no-wall']}>
  <svg class="tagline-eye" viewBox="0 0 100 100" aria-hidden="true">
    <path d="M 4 50 Q 50 -20 96 50 Q 50 120 4 50 Z" fill="#4169E1"/>
    <circle cx="50" cy="50" r="14" fill="#FFFFFF"/>
  </svg>
  Ensaios de um <em>não-candango</em> no Planalto.
</div>

{isHome && (
  <Fragment>
    <!-- Symbol def do Grade cobogó (inline, usado pelo script abaixo via getElementById) -->
    <svg style="position:absolute;width:0;height:0;overflow:hidden" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      <symbol id="cobogo-grade" viewBox="0 0 177 177" preserveAspectRatio="xMidYMid meet">
        <g transform="translate(0,177) scale(0.1,-0.1)" fill-rule="evenodd">
          <path fill="currentColor" fill-rule="evenodd" d="M10 885 l0 -885 880 0 880 0 0 885 0 885 -880 0 -880 0 0 -885z m400 610 l0 -125 -125 0 -125 0 0 125 0 125 125 0 125 0 0 -125z m410 0 l0 -125 -130 0 -130 0 0 125 0 125 130 0 130 0 0 -125z m400 0 l0 -125 -125 0 -125 0 0 125 0 125 125 0 125 0 0 -125z m410 0 l0 -125 -125 0 -125 0 0 125 0 125 125 0 125 0 0 -125z m-1220 -410 l0 -125 -125 0 -125 0 0 125 0 125 125 0 125 0 0 -125z m410 0 l0 -125 -130 0 -130 0 0 125 0 125 130 0 130 0 0 -125z m400 0 l0 -125 -125 0 -125 0 0 125 0 125 125 0 125 0 0 -125z m410 0 l0 -125 -125 0 -125 0 0 125 0 125 125 0 125 0 0 -125z m-1220 -405 l0 -130 -125 0 -125 0 0 130 0 130 125 0 125 0 0 -130z m408 3 l-3 -128 -125 0 -125 0 -3 114 c-1 63 0 121 2 128 4 10 37 13 131 13 l126 0 -3 -127z m402 -3 l0 -130 -125 0 -125 0 0 130 0 130 125 0 125 0 0 -130z m410 0 l0 -130 -125 0 -125 0 0 130 0 130 125 0 125 0 0 -130z m-1220 -405 l0 -125 -125 0 -125 0 0 125 0 125 125 0 125 0 0 -125z m410 0 l0 -125 -130 0 -130 0 0 125 0 125 130 0 130 0 0 -125z m400 0 l0 -125 -125 0 -125 0 0 125 0 125 125 0 125 0 0 -125z m410 0 l0 -125 -125 0 -125 0 0 125 0 125 125 0 125 0 0 -125z"/>
        </g>
      </symbol>
    </svg>

    <section class="wall-section">
      <div class="stripe" id="stripe" aria-hidden="true"></div>
    </section>

    <script is:inline>
      (function() {
        const stripe = document.getElementById('stripe');
        if (!stripe) return;

        const isMobile = window.innerWidth < 760;
        const TILE = isMobile ? 36 : 44;
        const ROWS = isMobile ? 5 : 7;
        const DARK = '#1A1A1A';
        const TILE_COLOR = '#cdcfd6';

        const symbol = document.getElementById('cobogo-grade');
        if (!symbol) return;
        const viewBox = symbol.getAttribute('viewBox') || '0 0 177 177';
        const gradeInner = symbol.innerHTML.replace(/currentColor/g, TILE_COLOR);
        const gradeSvg = "<svg xmlns='http://www.w3.org/2000/svg' viewBox='" + viewBox + "'>" + gradeInner + "</svg>";
        const gradeUri = "data:image/svg+xml;utf8," + encodeURIComponent(gradeSvg).replace(/'/g, '%27').replace(/"/g, '%22');

        const congressSvg = "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1000 280' preserveAspectRatio='none'><g fill='" + DARK + "'><rect x='50' y='240' width='900' height='40'/><path d='M 180 240 A 75 60 0 0 1 330 240 Z'/><rect x='475' y='60' width='25' height='180'/><rect x='510' y='60' width='25' height='180'/><path d='M 670 240 L 670 170 Q 745 220 820 170 L 820 240 Z'/></g></svg>";
        const congressUri = "data:image/svg+xml;utf8," + encodeURIComponent(congressSvg).replace(/'/g, '%27').replace(/"/g, '%22');

        stripe.style.backgroundImage = 'url("' + gradeUri + '"), url("' + congressUri + '")';
        stripe.style.backgroundSize = TILE + 'px ' + TILE + 'px, 100% 100%';
        stripe.style.backgroundRepeat = 'repeat, no-repeat';
        stripe.style.backgroundPosition = '0 0, center center';
        stripe.style.height = (ROWS * TILE) + 'px';
      })();
    </script>
  </Fragment>
)}
