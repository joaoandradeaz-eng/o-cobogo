---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageIntro from '../components/PageIntro.astro';
import CobogoSymbols from '../components/CobogoSymbols.astro';

interface Props {
  title: string;
  active?: 'home' | 'sobre';
  screenLabel?: string;
}

const { title, active = 'home', screenLabel } = Astro.props;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/assets/icone.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bitter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600&family=Manrope:wght@500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body data-screen-label={screenLabel}>
    <CobogoSymbols />
    <a href="#main" class="skip-link">Pular para o conteúdo</a>
    <Header active={active} />
    <main id="main">
      <PageIntro />
      <slot />
    </main>
    <Footer />
  </body>
</html>
