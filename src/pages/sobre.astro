---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

function parseInlineMd(text: string): string {
  return text.replace(/\*([^*]+)\*/g, '<em>$1</em>');
}
const months = ['jan', 'fev', 'mar', 'abr', 'mai', 'jun', 'jul', 'ago', 'set', 'out', 'nov', 'dez'];
function fmtRowDate(date: Date): { day: string; year: string } {
  const m = months[date.getUTCMonth()];
  return {
    day: `${String(date.getUTCDate()).padStart(2, '0')} ${m.charAt(0).toUpperCase()}${m.slice(1)}`,
    year: `${date.getUTCFullYear()}`,
  };
}

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
allArticles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const recent = allArticles.slice(0, 6);
const total = allArticles.length;

const tags = await getCollection('tags');
const tagsBySlug = new Map(tags.map((t) => [t.id, t.data]));
function catName(slug: string): string {
  return tagsBySlug.get(slug)?.name ?? slug;
}
---
<BaseLayout title="Sobre · O Cobogó" active="sobre" screenLabel="Sobre" description="João Andrade — escreve sobre cidade, cultura e arquitetura em O Cobogó.">

  <!-- HERO DO AUTOR -->
  <section class="author-hero">
    <div class="rule"></div>
    <div class="label">Sobre o autor</div>
    <div class="pad">
      <div class="photo">
        <picture>
          <source type="image/webp" srcset="/assets/joao-andrade-360.webp" />
          <img src="/assets/joao-andrade-360.jpg" alt="Retrato de João Andrade" loading="eager" decoding="async" width="180" height="180" />
        </picture>
      </div>
      <div>
        <h1>João Andrade</h1>
      </div>
    </div>
  </section>

  <!-- BIOGRAFIA -->
  <section class="bio">
    <p><span class="first">João Andrade construiu carreira no setor privado</span>, em São Paulo, ao longo de mais de dez anos — antes de a vida o trazer para Brasília. Vem de uma família de pequenos comerciantes, três gerações dedicadas ao balcão e à rua, e talvez por isso nunca tenha conseguido olhar uma cidade sem ver, primeiro, as pessoas que a fazem funcionar.</p>
    <p>Mudou-se para o Planalto por amor — a esposa, advogada — e ali encontrou um ofício que não procurava: o de agregar, conciliar e costurar interesses. Hoje trabalha com relações institucionais e governamentais, ao lado de quem representa milhões de pequenos empreendedores do país. Aprendeu, no caminho, que <em>a influência mais duradoura é a que não se anuncia</em> — lição que serve à política e, descobriu depois, também à escrita.</p>
    <p>O Cobogó nasceu do outro lado dessa rotina. Se o trabalho é a pauta, aqui mora o olhar. O cobogó — aquele elemento vazado que filtra a luz e deixa passar o vento sem deixar passar tudo — deu nome e método à revista: uma forma de olhar a cidade que separa o ruído do que de fato importa. João escreve sobre o que está entre a casa e a rua, entre o que se constrói e o que se decide.</p>
    <p>Acredita que <em>cidade é uma forma de pensar</em>, e que a melhor maneira de entender um lugar é continuar, por algum tempo, estrangeiro a ele. Filho de um professor universitário, cresceu cercado pelo peso das ideias — e faz desta revista o lugar onde anota, sem pressa, o que vê.</p>
    <p class="closing">Não nasceu candango. Chegou ao Planalto vindo de fora e ficou — e é dessa distância, a de quem ainda estranha, que escreve sobre a cidade, a cultura e o que passa entre uma e&nbsp;outra.</p>
    <div class="signature">— j. a.</div>
  </section>

  <!-- ARQUIVO SELECIONADO -->
  {recent.length > 0 && (
  <section class="arquivo">
    <div class="head">
      <h2>Próximas <em>leituras</em></h2>
      <a href="/arquivo" class="more">Arquivo completo ({total}) →</a>
    </div>

    {recent.map((a) => {
      const d = fmtRowDate(a.data.date);
      return (
      <a class="row" href={`/${a.id}`}>
        <div class="date">{d.day}<br/>{d.year}</div>
        <h3 set:html={parseInlineMd(a.data.title)}></h3>
        <div class="where">{catName(a.data.categories[0])} · O Cobogó</div>
        <div class="thumb">imagem</div>
      </a>
      );
    })}
  </section>
  )}
</BaseLayout>

<style is:global>
  /* ========== AUTHOR HERO ========== */
  .author-hero{
    max-width:1280px;margin:48px auto 0;
    padding:0 var(--gutter);
  }
  /* linha preta inset (acompanha as margens do conteúdo) */
  .author-hero .rule{
    height:14px;background:#000;
  }
  .author-hero .label{
    font-family:var(--sans);font-size:13px;font-weight:700;
    letter-spacing:.18em;text-transform:uppercase;color:#000;
    padding-top:14px;
  }
  .author-hero .pad{
    padding:32px 0 64px;
    display:grid;grid-template-columns:auto 1fr;
    gap:48px;align-items:center;
    border-bottom:1px solid var(--rule);
  }
  .author-hero .photo{
    width:180px;height:180px;border-radius:50%;
    overflow:hidden;background:var(--paper-2);
    border:1px solid var(--ink);position:relative;flex-shrink:0;
  }
  .author-hero .photo img{
    width:100%;height:100%;object-fit:cover;object-position:50% 22%;display:block;
  }
  .author-hero h1{
    font-family:var(--serif);font-weight:500;
    font-size:60px;line-height:1.0;letter-spacing:-.02em;
    color:#000;margin:0 0 14px;
  }
  .author-hero h1 em{font-style:italic;font-weight:400}
  .author-hero .lede{
    font-family:var(--serif);font-style:italic;
    font-size:22px;line-height:1.35;color:var(--ink-2);
    max-width:48ch;font-weight:400;
  }
  @media (max-width:760px){
    .author-hero{padding:0 20px;margin-top:32px}
    .author-hero .pad{
      grid-template-columns:1fr;padding:24px 0 40px;gap:24px;
    }
    .author-hero .photo{width:140px;height:140px}
    .author-hero h1{font-size:48px}
    .author-hero .lede{font-size:18px}
  }

  /* ========== BIOGRAFIA ========== */
  .bio{
    max-width:1280px;margin:0 auto;
    padding:64px var(--gutter);
    border-bottom:1px solid var(--rule);
  }
  .bio h2{
    font-family:var(--serif);font-weight:500;
    font-size:48px;letter-spacing:-.018em;line-height:1;
    color:#000;margin-bottom:32px;
  }
  .bio h2 em{font-style:italic;font-weight:400}
  .bio p{
    font-family:var(--serif);font-size:24px;line-height:1.5;
    color:var(--ink);margin-bottom:22px;
    text-wrap:pretty;max-width:64ch;
  }
  .bio p em{font-style:italic;color:var(--ink)}
  .bio p .first{font-family:var(--serif);font-style:italic;color:var(--ink-3)}
  /* frase de fecho (era a lede do topo) — destacada como kicker do texto */
  .bio .closing{
    margin-top:36px;
    font-family:var(--serif);font-style:italic;
    font-size:27px;line-height:1.4;color:#000;
    max-width:60ch;text-wrap:pretty;
  }
  .bio .signature{
    margin-top:40px;font-family:var(--serif);
    font-style:italic;font-size:18px;color:var(--ink-3);
  }
  @media (max-width:760px){
    .bio{padding:48px 20px}
    .bio h2{font-size:32px}
    .bio p{font-size:19px}
    .bio .closing{font-size:21px}
  }

  /* ========== ARQUIVO SELECIONADO ========== */
  .arquivo{
    max-width:1280px;margin:0 auto;
    padding:0 var(--gutter) 64px;
  }
  .arquivo .head{
    padding:60px 0 24px;
    border-bottom:1px solid var(--ink);
    display:flex;align-items:baseline;justify-content:space-between;
    margin-bottom:0;
  }
  .arquivo .head h2{
    font-family:var(--serif);font-weight:500;
    font-size:40px;letter-spacing:-.018em;color:#000;
  }
  .arquivo .head h2 em{
    font-style:italic;color:var(--terra-deep);font-weight:400;
  }
  .arquivo .head .more{
    font-family:var(--mono);font-size:11px;
    letter-spacing:.14em;text-transform:uppercase;color:var(--ink-3);
  }
  .arquivo a.row{
    display:grid;grid-template-columns:90px 1fr 200px 96px;
    gap:24px;align-items:center;
    padding:28px 0;border-bottom:1px solid var(--rule);
    transition:background .2s ease, color .2s ease, padding .2s ease;
    color:#000;
  }
  .arquivo a.row:hover{background:#000;color:#fff;padding-left:24px;padding-right:24px}
  .arquivo a.row:hover .date,
  .arquivo a.row:hover h3,
  .arquivo a.row:hover .where,
  .arquivo a.row:hover .thumb{color:#fff}
  .arquivo .date{
    font-family:var(--sans);font-size:13px;
    letter-spacing:.04em;color:#000;font-weight:500;line-height:1.3;
  }
  .arquivo h3{
    font-family:var(--serif);font-weight:500;
    font-size:28px;line-height:1.15;letter-spacing:-.005em;
    text-wrap:balance;color:#000;margin:0;
  }
  .arquivo h3 em{font-style:italic;font-weight:400}
  .arquivo .where{
    font-family:var(--serif);font-style:italic;font-size:16px;
    color:var(--ink-3);text-align:right;
  }
  .arquivo .thumb{
    width:96px;height:96px;background:#b89072;
    display:flex;align-items:center;justify-content:center;
    font-family:var(--sans);font-size:10px;
    letter-spacing:.16em;text-transform:uppercase;color:#000a;
    flex-shrink:0;
  }
  @media (max-width:760px){
    .arquivo a.row{
      grid-template-columns:1fr;gap:8px;padding:20px 0;
    }
    .arquivo .where{text-align:left}
    .arquivo .thumb{width:100%;height:80px}
  }
</style>
