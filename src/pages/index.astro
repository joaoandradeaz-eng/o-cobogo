---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import AuthorInsert from '../components/AuthorInsert.astro';
import Tag from '../components/Tag.astro';
import { getCollection } from 'astro:content';

// converte *texto* (markdown emphasis) em <em>texto</em>; igual ao [slug].astro
function parseInlineMd(text: string): string {
  return text.replace(/\*([^*]+)\*/g, '<em>$1</em>');
}

const months = ['jan', 'fev', 'mar', 'abr', 'mai', 'jun', 'jul', 'ago', 'set', 'out', 'nov', 'dez'];
// "12 mar 2026 · 14 min" (UTC pra evitar timezone shift)
function fmtMeta(date: Date, readTime: string): string {
  const ds = `${String(date.getUTCDate()).padStart(2, '0')} ${months[date.getUTCMonth()]} ${date.getUTCFullYear()}`;
  return readTime ? `${ds} · ${readTime}` : ds;
}
// coluna de data da stack: { day: "11 Mar", year: "2026" }
function fmtStackDate(date: Date): { day: string; year: string } {
  const m = months[date.getUTCMonth()];
  return {
    day: `${String(date.getUTCDate()).padStart(2, '0')} ${m.charAt(0).toUpperCase()}${m.slice(1)}`,
    year: `${date.getUTCFullYear()}`,
  };
}

// Artigos publicados, mais recentes primeiro. Cada slot do layout puxa em ordem;
// o que sobra além dos 4 primeiros cai na lista "Outras leituras" (stack).
const published = await getCollection('articles', ({ data }) => !data.draft);
published.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const hero = published[0];
const pair = published.slice(1, 3);
const big = published[3];
const stack = published.slice(4, 7); // capa mostra no máx. 7 artigos; o resto vai pro /arquivo
const hasMore = published.length > 7;
---
<BaseLayout title="O Cobogó · revista de cidade, cultura e arquitetura" active="home" screenLabel="Home" description="Revista editorial sobre cidade, cultura e arquitetura — por João Andrade. Nova edição toda semana.">

  <div class="shell">
    <div class="feed">

      <!-- HERO c12 -->
      {hero && (
      <div class="c12 hero">
        <article class="card">
          <div class="tags"><Tag slug={hero.data.categories[0]} /></div>
          <div class="rule"></div>
          <h2><a href={`/${hero.id}`} set:html={parseInlineMd(hero.data.title)}></a></h2>
          <p class="dek" set:html={parseInlineMd(hero.data.dek)}></p>
          <p class="by">
            <a href="/sobre" class="by-author">
              <img src="/assets/joao-andrade-48.jpg" alt="" loading="eager" decoding="async" width="24" height="24" />
              por <span set:html={parseInlineMd(hero.data.author)}></span>
            </a>
            <span class="dot" aria-hidden="true">·</span>
            <span class="meta-inline">{fmtMeta(hero.data.date, hero.data.readTime)}</span>
          </p>
          <figure class="ph-a"><span class="ph">imagem · placeholder</span></figure>
        </article>
      </div>
      )}

      <!-- 2 cards lado a lado, alinhados via subgrid -->
      {pair.length > 0 && (
      <div class="pair">
        {pair.map((a, i) => (
        <article class="card">
          <div class="tags"><Tag slug={a.data.categories[0]} /></div>
          <div class="rule"></div>
          <h2><a href={`/${a.id}`} set:html={parseInlineMd(a.data.title)}></a></h2>
          <p class="dek" set:html={parseInlineMd(a.data.dek)}></p>
          <p class="by">
            <a href="/sobre" class="by-author">
              <img src="/assets/joao-andrade-48.jpg" alt="" loading="lazy" decoding="async" width="24" height="24" />
              por <span set:html={parseInlineMd(a.data.author)}></span>
            </a>
            <span class="dot" aria-hidden="true">·</span>
            <span class="meta-inline">{fmtMeta(a.data.date, a.data.readTime)}</span>
          </p>
          <figure class={i === 0 ? 'ph-c' : 'ph-b'}><span class="ph">imagem</span></figure>
        </article>
        ))}
      </div>
      )}

      <!-- 1 grande à esquerda + 3 empilhadas à direita -->
      {big && (
      <div class="row-1plus3">
        <div class="big">
          <div class="tags"><Tag slug={big.data.categories[0]} /></div>
          <div class="rule"></div>
          <article class="card">
            <h2><a href={`/${big.id}`} set:html={parseInlineMd(big.data.title)}></a></h2>
            <p class="dek" set:html={parseInlineMd(big.data.dek)}></p>
            <p class="by">
              <a href="/sobre" class="by-author">
                <img src="/assets/joao-andrade-48.jpg" alt="" loading="lazy" decoding="async" width="24" height="24" />
                por <span set:html={parseInlineMd(big.data.author)}></span>
              </a>
              <span class="dot" aria-hidden="true">·</span>
              <span class="meta-inline">{fmtMeta(big.data.date, big.data.readTime)}</span>
            </p>
            <figure class="ph-d"><span class="ph">imagem</span></figure>
          </article>
        </div>
        <div class="stack">
          <div class="tags-spacer" aria-hidden="true"></div>
          <div class="rule"></div>
          <div class="stack-body">
            {stack.length > 0 && (
            <header class="stack-head">
              <h2>Outras <em>leituras</em></h2>
            </header>
            )}
            {stack.map((a) => {
              const sd = fmtStackDate(a.data.date);
              return (
              <a class="stack-link" href={`/${a.id}`}>
                <div class="date">{sd.day}<br/>{sd.year}</div>
                <div class="body">
                  <h2 set:html={parseInlineMd(a.data.title)}></h2>
                  <p class="dek" set:html={parseInlineMd(a.data.dek)}></p>
                  <p class="by">
                    <span class="by-author">
                      <img src="/assets/joao-andrade-48.jpg" alt="" loading="lazy" decoding="async" width="24" height="24" />
                      por <span set:html={parseInlineMd(a.data.author)}></span>
                    </span>
                    <span class="dot" aria-hidden="true">·</span>
                    <span class="meta-inline">{fmtMeta(a.data.date, a.data.readTime)}</span>
                  </p>
                </div>
                <div class="thumb">imagem</div>
              </a>
              );
            })}
          </div>
        </div>
      </div>
      )}

      <!-- VER MAIS: só aparece quando há artigos além dos 7 da capa -->
      {hasMore && (
      <div class="see-more">
        <a href="/arquivo" class="see-more-btn">Ver todos os artigos →</a>
      </div>
      )}

      <!-- INSERT: SOBRE O AUTOR -->
      <AuthorInsert inFeed={true} />

    </div>
  </div>
</BaseLayout>

<style is:global>
  /* ========== TAGS de categoria (chips coloridos acima da linha preta) ========== */
  .tags{
    display:flex;flex-wrap:wrap;align-items:center;gap:16px;
  }
  /* o chip (.tag) e a peça (.tag-mark) são estilizados globalmente (Tag.astro) */

  /* spacer invisível: reserva a mesma altura das .tags pra manter a
     linha preta da .stack alinhada com a da .big no row-1plus3 */
  .tags-spacer{height:22px}

  /* ========== VER MAIS (link pro /arquivo) ========== */
  .see-more{
    grid-column:span 12;border-right:none;
    display:flex;justify-content:center;
    padding:8px var(--pad-x) 64px;
  }
  .see-more-btn{
    display:inline-flex;align-items:center;gap:12px;
    font-family:var(--mono);font-size:12px;font-weight:500;
    letter-spacing:.16em;text-transform:uppercase;color:#000;
    border:1px solid var(--ink);border-radius:2px;
    padding:14px 28px;background:transparent;
    transition:background-color .2s ease, color .2s ease;
  }
  .see-more-btn:hover{background:#000;color:#fff}
  @media (max-width:760px){
    .see-more{padding:0 var(--pad-x) 40px}
  }

  /* ========== DEK (spoiler de 2-3 linhas) ========== */
  article.card .dek{
    font-family:var(--serif);font-style:normal;font-weight:400;
    font-size:18px;line-height:1.45;color:var(--ink-2);
  }
  @media (max-width:980px){
    article.card .dek{font-size:16px}
  }

  /* ========== BYLINE: nome italic + data/tempo em mono uppercase ========== */
  article.card .by .dot{
    font-style:normal;color:var(--rule-strong);
  }
  article.card .by .meta-inline{
    font-family:var(--mono);font-style:normal;font-weight:500;
    font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;
    color:var(--ink-3);
  }

  /* ========== FEED (grade editorial 12 col) ========== */
  main{padding:0}
  .feed{
    display:grid;grid-template-columns:repeat(12,1fr);gap:0;
  }
  .feed > article,.feed > .insert{
    padding:var(--pad-y) var(--pad-x);
  }

  /* card sizing variants — todos com mesmo padding lateral pra alinhar com o resto */
  .c12{grid-column:span 12;padding:64px var(--pad-x);border-right:none}
  .c8 {grid-column:span 8; padding:0 var(--pad-x)}
  .c6 {grid-column:span 6; padding:0 var(--pad-x)}
  .c4 {grid-column:span 4; padding:0 var(--pad-x)}
  .c3 {grid-column:span 3; padding:0 var(--pad-x)}
  @media (max-width:1000px){
    .c8,.c6{grid-column:span 12;border-right:none}
    .c4{grid-column:span 6}
    .c3{grid-column:span 6}
  }
  @media (max-width:640px){
    .c4,.c3{grid-column:span 12;border-right:none}
  }

  /* ========== card (componente repetido) ========== */
  article.card{display:flex;flex-direction:column;gap:14px}
  /* RULE preta como elemento próprio (não mais border-top do h2) */
  article.card > .rule{
    height:12px;background:#000;
    margin-bottom:-2px;
  }
  article.card h2{
    font-family:var(--display);font-weight:700;
    line-height:1.02;letter-spacing:-.022em;
    font-variation-settings:"opsz" 48;
    color:#000;
  }
  article.card h2 a{
    display:inline;color:#000;
    background-image:linear-gradient(#000,#000);
    background-repeat:no-repeat;
    background-size:0 1px;
    background-position:0 100%;
    transition:background-size .35s ease;
  }
  article.card:hover h2 a{background-size:100% 1px}
  article.card h2 em{font-style:normal;font-weight:700}
  article.card .by{
    font-family:var(--serif);font-style:italic;font-size:16px;color:var(--ink-2);
    display:flex;flex-wrap:wrap;align-items:center;gap:6px 12px;
  }
  article.card figure{
    margin-top:6px;position:relative;overflow:hidden;
    background:var(--paper-2);border:1px solid var(--rule-strong);
  }
  article.card figure .ph{
    position:absolute;inset:0;
    display:flex;align-items:center;justify-content:center;
    font-family:var(--mono);font-size:10px;
    letter-spacing:.16em;text-transform:uppercase;color:var(--ink-3);
  }

  /* tamanhos do h2 por size */
  .c12 article.card h2{font-size:68px;font-variation-settings:"opsz" 60;line-height:1.0}
  .c8  article.card h2{font-size:54px}
  .c6  article.card h2{font-size:76px;line-height:1.03}
  .c4  article.card h2{font-size:30px}
  .c3  article.card h2{font-size:26px}
  @media (max-width:980px){
    .c12 article.card h2{font-size:44px}
    .c8  article.card h2{font-size:34px}
    .c6  article.card h2{font-size:46px}
  }

  /* aspect-ratio das imagens por size */
  .c12 article.card figure{aspect-ratio:21/9}
  .c8  article.card figure{aspect-ratio:16/9}
  .c6  article.card figure{aspect-ratio:4/3}
  .c4  article.card figure,.c3 article.card figure{aspect-ratio:4/3}

  /* placeholders decorativos para figuras (sem foto real) */
  .ph-a{background:repeating-linear-gradient(135deg, rgba(27,22,18,.06) 0 1px, transparent 1px 14px), linear-gradient(160deg,var(--paper-3),var(--paper-2))}
  .ph-b{background:radial-gradient(circle at 30% 40%, var(--terra-tint), transparent 60%), linear-gradient(180deg,var(--paper-3),var(--paper-2))}
  .ph-c{background:linear-gradient(135deg,#2A241D 0 60%, var(--paper-3) 60% 100%)}
  .ph-d{background:repeating-linear-gradient(0deg, var(--paper-3) 0 8px, var(--paper-2) 8px 16px)}

  /* by-author italic dentro do .by */
  .by .by-author{font-style:italic}

  /* ========== PAIR (2 cards lado a lado, alinhados via subgrid) ==========
     6 trilhos: tags, rule, h2, dek, by, figure — todas as linhas pareiam
     horizontalmente; row-gap:14px garante espaçamento uniforme entre rows. */
  .pair{
    grid-column:span 12;border-right:none;
    display:grid;grid-template-columns:1fr 1fr;
    grid-template-rows:repeat(6, auto);
    column-gap:0;row-gap:14px;
    padding:48px 0;
  }
  .pair > article.card{
    display:grid;grid-row:1 / span 6;
    grid-template-rows:subgrid;
    padding:0 var(--pad-x);
    row-gap:14px;column-gap:0;
    border-right:1px solid var(--rule);
  }
  .pair > article.card:last-child{border-right:none}
  .pair > article.card > .tags{align-self:end}
  .pair > article.card > .rule{align-self:start;margin:0}
  .pair > article.card h2{align-self:start;font-size:34px;line-height:1.12}
  .pair > article.card .dek{align-self:start}
  .pair > article.card .by{align-self:start}
  .pair > article.card figure{
    align-self:stretch;margin-top:0;
    aspect-ratio:4/3;
  }
  @media (max-width:880px){
    .pair{grid-template-columns:1fr;grid-template-rows:none;padding:48px 0 0}
    .pair > article.card{
      grid-row:auto;display:flex;flex-direction:column;gap:14px;
      border-right:none;
      padding:0 var(--pad-x) 48px;
    }
    /* no flex column, align-self:end encostaria a badge à direita — força à esquerda */
    .pair > article.card > .tags{align-self:flex-start}
    .pair > article.card h2{font-size:24px}
  }

  /* ========== row-1plus3 ==========
     subgrid de 3 linhas (tags, rule, conteúdo) trava as duas linhas pretas no
     mesmo Y. O conteúdo da direita determina a altura — a figura da esquerda
     usa flex:1 pra estender e terminar exatamente onde a última stack-link termina. */
  .row-1plus3{
    grid-column:span 12;border-right:none;
    display:grid;
    grid-template-columns:1fr 1fr;
    grid-template-rows:auto auto 1fr;
    row-gap:14px;
    margin-bottom:64px;
    align-items:stretch;
  }
  .row-1plus3 > .big,
  .row-1plus3 > .stack{
    display:grid;
    grid-row:1 / span 3;
    grid-template-rows:subgrid;
    padding:48px var(--pad-x);
  }
  .row-1plus3 > .stack{border-left:1px solid var(--rule)}
  .row-1plus3 > .big > .rule,
  .row-1plus3 > .stack > .rule{
    height:12px;background:#000;margin:0;
    align-self:start;
  }
  .row-1plus3 > .big > .tags{align-self:end}
  .row-1plus3 > .stack > .tags-spacer{align-self:end;height:1px}

  /* big = card que estica e termina junto da .stack */
  .row-1plus3 > .big > article.card{
    display:flex;flex-direction:column;gap:14px;
    height:100%;  /* preenche row 3 */
  }
  .row-1plus3 > .big > article.card > .rule{display:none}
  .row-1plus3 > .big article.card h2{font-size:40px;line-height:1.05}
  @media (max-width:980px){
    .row-1plus3 > .big article.card h2{font-size:28px}
  }
  .row-1plus3 > .big article.card figure{
    margin-top:0;
    aspect-ratio:auto;
    flex:1;min-height:240px;
  }

  /* stack-body = wrapper de header + links na row 3 */
  .row-1plus3 > .stack > .stack-body{
    display:flex;flex-direction:column;
  }

  /* kicker "OUTRAS LEITURAS" — espelha as tags coloridas do lado esquerdo */
  .row-1plus3 > .stack .stack-head{
    margin-bottom:8px;
    padding-bottom:14px;
  }
  .row-1plus3 > .stack .stack-head h2{
    font-family:var(--mono);font-weight:500;
    font-size:14px;letter-spacing:.18em;text-transform:uppercase;
    color:var(--ink-3);margin:0;line-height:1;
  }
  .row-1plus3 > .stack .stack-head h2 em{
    font-style:normal;font-weight:500;color:inherit;
  }

  .row-1plus3 > .stack .stack-link{
    display:grid;grid-template-columns:64px 1fr 140px;
    gap:20px;align-items:center;
    padding:22px 16px;
    margin:0 -16px;
    border-radius:2px;
    transition:background-color .2s ease, color .2s ease;
    color:#000;
  }
  .row-1plus3 > .stack .stack-link:hover{background-color:rgba(27,22,18,.05)}
  .row-1plus3 > .stack .stack-link:hover h2{color:var(--terra-deep)}
  .row-1plus3 > .stack .stack-link:hover .thumb{transform:scale(1.04)}
  .row-1plus3 > .stack .stack-link .date{
    font-family:var(--mono);font-size:11px;
    letter-spacing:.14em;text-transform:uppercase;
    color:var(--ink-3);font-weight:500;line-height:1.4;
  }
  .row-1plus3 > .stack .stack-link .body{min-width:0;display:flex;flex-direction:column;gap:6px}
  .row-1plus3 > .stack .stack-link h2{
    font-size:22px;font-family:var(--display);
    font-weight:700;line-height:1.15;letter-spacing:-.008em;
    text-wrap:balance;color:#000;margin:0;
  }
  .row-1plus3 > .stack .stack-link .dek{
    font-family:var(--serif);font-size:14px;line-height:1.4;
    color:var(--ink-2);margin:0;
    display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;
    overflow:hidden;
  }
  .row-1plus3 > .stack .stack-link .by{
    font-family:var(--serif);font-style:italic;
    font-size:13px;color:var(--ink-2);margin:0;
  }
  /* avatar menor (18px) pra escala do texto 13px italic do stack-link */
  .row-1plus3 > .stack .stack-link .by .by-author > img{
    width:18px;height:18px;
  }
  .row-1plus3 > .stack .stack-link .thumb{
    width:140px;height:140px;background:#b89072;
    display:flex;align-items:center;justify-content:center;
    font-family:var(--mono);font-size:9px;
    letter-spacing:.16em;text-transform:uppercase;color:#000a;
    flex-shrink:0;
    transition:transform .25s ease;
    box-shadow:inset 0 0 0 1px rgba(0,0,0,.08);
  }
  /* ========== DESKTOP: dentro do stack-link, esconde o meta-inline
     (data + tempo) porque a coluna grande de data à esquerda já mostra. */
  .row-1plus3 > .stack .stack-link .by .meta-inline,
  .row-1plus3 > .stack .stack-link .by .dot{display:none}

  /* ========== MOBILE (760px): byline numa linha só + dek truncado ========== */
  @media (max-width:760px){
    /* hero/c12 com menos respiro vertical no mobile */
    .c12{padding:32px var(--pad-x) 40px}

    /* headline da capa: 36px no mobile (era 44) — segura presença mas deixa
       dek + byline + imagem aparecerem na primeira dobra */
    .c12 article.card h2{font-size:36px;line-height:1.06}

    /* capa: 3/2 no mobile em vez de 21/9 (que virava uma tarja de ~120px);
       fica mais cheia que os cards 4/3, sinalizando que é a matéria líder */
    .c12 article.card figure{aspect-ratio:3/2}

    /* dek truncado em 3 linhas em todos os cards principais */
    article.card .dek{
      display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;
      overflow:hidden;
    }

    /* byline: inline quando cabe; quando não cabe, a data/tempo quebra inteira
       pra linha de baixo (nunca corta "14 min" no meio com reticências) */
    article.card .by{
      font-size:14px;gap:4px 8px;flex-wrap:wrap;align-items:center;
    }
    article.card .by .by-author > img{width:20px;height:20px}
    article.card .by .by-author{flex-shrink:0}
    /* sem o ponto separador: na quebra ele ficaria órfão no início da linha 2 */
    article.card .by .dot{display:none}
    article.card .by .meta-inline{
      font-size:9.5px;letter-spacing:.1em;white-space:nowrap;
    }
  }

  /* ========== MOBILE (880px): stack-link redesenhado como card vertical ========== */
  @media (max-width:880px){
    .row-1plus3{grid-template-columns:1fr;grid-template-rows:none;margin-bottom:32px}
    .row-1plus3 > .big,
    .row-1plus3 > .stack{
      grid-row:auto;display:flex;flex-direction:column;gap:14px;
      padding:32px var(--pad-x);
    }
    .row-1plus3 > .stack{border-left:none;border-top:1px solid var(--rule);padding-top:32px}
    /* mesma correção do align-self da .pair: badge à esquerda no flex column */
    .row-1plus3 > .big > .tags{align-self:flex-start}
    .row-1plus3 > .big article.card figure{min-height:0}

    /* stack-link vira card vertical com rule preto em cima, sem date column nem thumb */
    .row-1plus3 > .stack .stack-link{
      display:flex;flex-direction:column;gap:12px;
      padding:0;margin:0;
      position:relative;
    }
    .row-1plus3 > .stack .stack-link::before{
      content:'';display:block;
      height:12px;background:#000;
      /* o .stack-link herda align-items:center do desktop; sem o stretch a barra
         (conteúdo vazio) colapsa pra 0px de largura e fica invisível */
      align-self:stretch;
      margin-bottom:4px;
    }
    .row-1plus3 > .stack .stack-link .date,
    .row-1plus3 > .stack .stack-link .thumb{display:none}
    .row-1plus3 > .stack .stack-link .by .meta-inline,
    .row-1plus3 > .stack .stack-link .by .dot{display:inline}
    .row-1plus3 > .stack .stack-link h2{font-size:26px;line-height:1.1}
    .row-1plus3 > .stack .stack-link .dek{
      font-size:16px;-webkit-line-clamp:3;
    }
    .row-1plus3 > .stack .stack-link .by{
      font-size:14px;display:flex;flex-wrap:nowrap;
      align-items:center;gap:4px 8px;
    }
    .row-1plus3 > .stack .stack-link .by .by-author > img{width:20px;height:20px}
    .row-1plus3 > .stack .stack-link .by .meta-inline{
      font-size:9.5px;letter-spacing:.12em;
      white-space:nowrap;overflow:hidden;text-overflow:ellipsis;min-width:0;
    }

    /* stack-body: separa visualmente cada link com gap maior */
