---
import { getCollection } from 'astro:content';
import { getSession, isAuthorized } from '../../../lib/session';

const session = await getSession(Astro.cookies);
if (!isAuthorized(session)) {
  return Astro.redirect('/api/auth/login', 302);
}

const { slug } = Astro.params;
const articles = await getCollection('articles');
const article = articles.find((a) => a.id === slug);
if (!article) {
  return new Response('Artigo não encontrado', { status: 404 });
}
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Editar · {article.data.title} · Admin</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    body{font-family:system-ui,sans-serif;max-width:680px;margin:60px auto;padding:0 24px;line-height:1.5;color:#111}
    .stub{padding:48px 24px;text-align:center;border:1px dashed #ddd;border-radius:8px;color:#888}
    .stub h1{color:#111;margin-top:0;font-size:22px}
    .stub .title{color:#444;font-style:italic;margin:8px 0 24px}
    a{color:#666}
  </style>
</head>
<body>
  <div class="stub">
    <h1>Editor — em breve</h1>
    <p class="title">"{article.data.title}"</p>
    <p>A edição de posts já existentes vem na <strong>Fase 4</strong>.</p>
    <p style="margin-top:24px"><a href="/admin">← Voltar pro dashboard</a></p>
  </div>
</body>
</html>
