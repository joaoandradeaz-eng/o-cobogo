---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleEditor from '../../../components/ArticleEditor';
import { getSession, isAuthorized } from '../../../lib/session';
import { markdownToHtml } from '../../../lib/markdown';
import '../../../styles/article.css';

const session = await getSession(Astro.cookies);
if (!isAuthorized(session)) {
  return Astro.redirect('/api/auth/login', 302);
}

const { slug } = Astro.params;
const articles = await getCollection('articles');
const article = articles.find((a) => a.id === slug);
if (!article) {
  return new Response('Artigo não encontrado', { status: 404 });
}

const authorName = session.name?.split(' ').slice(0, 2).join(' ') || 'João Andrade';

const cloudinary = {
  cloudName: import.meta.env.CLOUDINARY_CLOUD_NAME ?? '',
  uploadPreset: import.meta.env.CLOUDINARY_UPLOAD_PRESET ?? '',
};

const tagsCollection = await getCollection('tags');
tagsCollection.sort((a, b) => {
  const oa = a.data.order ?? 100;
  const ob = b.data.order ?? 100;
  if (oa !== ob) return oa - ob;
  return a.data.name.localeCompare(b.data.name);
});
const tags = tagsCollection.map((t) => ({
  value: t.id,
  label: t.data.name,
  color: t.data.color,
  textColor: t.data.textColor,
}));

const d = article.data;
const initial = {
  title: d.title,
  dek: d.dek,
  categories: d.categories,
  date: d.date.toISOString().slice(0, 10),
  readTime: d.readTime,
  linhaFina: d.linhaFina ?? '',
  linhaFinaLabel: d.linhaFinaLabel ?? 'Linha-fina',
  notas: d.notas ?? [],
  bodyHtml: markdownToHtml(article.body ?? ''),
  draft: d.draft ?? false,
  heroImage: d.heroImage ?? '',
  heroCaption: d.heroCaption ?? '',
  heroPosition: d.heroPosition ?? '50% 50%',
  heroZoom: d.heroZoom ?? 1,
};
---
<BaseLayout title={`Editar · ${d.title} · Admin`} active="home" screenLabel="Editor">
  <ArticleEditor
    client:only="react"
    mode="edit"
    slug={article.id}
    initial={initial}
    authorName={authorName}
    cloudinary={cloudinary}
    tags={tags}
  />
</BaseLayout>
