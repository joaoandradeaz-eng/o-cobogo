---
import { getCollection } from 'astro:content';
import { getSession, isAuthorized } from '../../lib/session';

const session = await getSession(Astro.cookies);
if (!isAuthorized(session)) {
  return Astro.redirect('/api/auth/login', 302);
}

const articles = await getCollection('articles');
articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const published = articles.filter((a) => !a.data.draft);
const drafts = articles.filter((a) => a.data.draft);

const categoryLabels: Record<string, string> = {
  'ensaio': 'Ensaio',
  'reportagem': 'Reportagem',
  'critica': 'Crítica',
  'entrevista': 'Entrevista',
  'memoria': 'Memória',
  'cidade-casa': 'Cidade & Casa',
};

const fmtDate = new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin · O Cobogó</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    *{box-sizing:border-box}
    body{font-family:system-ui,-apple-system,sans-serif;max-width:920px;margin:0 auto;padding:40px 24px;line-height:1.5;color:#111}
    header.top{display:flex;justify-content:space-between;align-items:center;margin-bottom:32px;gap:16px}
    .brand{display:flex;align-items:center;gap:12px}
    .brand h1{font-size:24px;margin:0;font-weight:700}
    .brand .sub{color:#888;font-size:13px;font-family:ui-monospace,SFMono-Regular,Menlo,monospace}
    .session{display:flex;align-items:center;gap:10px;font-size:13px;color:#555}
    .session img{width:28px;height:28px;border-radius:50%}
    .session a{color:#666}

    .actions{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;gap:12px}
    .actions h2{font-size:18px;margin:0;color:#333}

    .section-block{margin-bottom:32px}
    .section-block:last-child{margin-bottom:0}
    .section-title{
      font-size:13px;font-weight:600;text-transform:uppercase;letter-spacing:.1em;
      color:#888;margin:0 0 10px 0;display:flex;align-items:baseline;gap:8px;
    }
    .section-title .count{
      font-size:11px;font-weight:500;color:#aaa;
      background:#f0f0f0;padding:2px 8px;border-radius:10px;
    }
    .btn-primary{
      display:inline-flex;align-items:center;gap:6px;
      padding:10px 16px;background:#d88854;color:#fff;
      text-decoration:none;border-radius:6px;font-size:14px;font-weight:600;
      transition:background .15s ease;
    }
    .btn-primary:hover{background:#c47842}

    .list{border:1px solid #e5e5e5;border-radius:8px;overflow:hidden}
    .row{
      display:grid;grid-template-columns:1fr auto auto auto;gap:16px;align-items:center;
      padding:16px 20px;border-top:1px solid #f0f0f0;
      text-decoration:none;color:inherit;
      transition:background .12s ease;
    }
    .row:first-child{border-top:none}
    .row:hover{background:#fafafa}
    .row .meta-col{min-width:0}
    .row h3{font-size:16px;margin:0 0 4px 0;font-weight:600;color:#111;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .row .dek{font-size:13px;color:#666;margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .row .cat{
      font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;
      padding:4px 8px;border-radius:4px;background:#f0f0f0;color:#444;
      white-space:nowrap;
    }
    .row .date{font-size:12px;color:#888;font-family:ui-monospace,SFMono-Regular,Menlo,monospace;white-space:nowrap}
    .row .badge-draft{
      font-size:10px;font-weight:700;letter-spacing:.1em;
      padding:3px 6px;border-radius:3px;
      background:#fef3c7;color:#92400e;text-transform:uppercase;
    }

    .empty{
      padding:48px 20px;text-align:center;color:#888;
      border:1px dashed #ddd;border-radius:8px;
    }
    .empty p{margin:8px 0}
    .empty .muted{font-size:13px}

    @media (max-width:640px){
      .row{grid-template-columns:1fr;gap:6px}
      .row .meta-col{order:1}
      .row .cat,.row .date,.row .badge-draft{justify-self:start}
    }
  </style>
</head>
<body>
  <header class="top">
    <div class="brand">
      <h1>O Cobogó</h1>
      <span class="sub">/admin</span>
    </div>
    <div class="session">
      {session.picture && <img src={session.picture} alt="" />}
      <span>{session.email}</span>
      <a href="/api/auth/logout">Sair</a>
    </div>
  </header>

  <div class="actions">
    <h2>{articles.length} {articles.length === 1 ? 'artigo' : 'artigos'} <span style="color:#aaa;font-weight:400;font-size:14px">· {published.length} publicado{published.length === 1 ? '' : 's'} · {drafts.length} rascunho{drafts.length === 1 ? '' : 's'}</span></h2>
    <a class="btn-primary" href="/admin/novo">+ Novo post</a>
  </div>

  {articles.length === 0 ? (
    <div class="empty">
      <p><strong>Sem artigos ainda.</strong></p>
      <p class="muted">Clica em "+ Novo post" pra começar.</p>
    </div>
  ) : (
    <>
      {drafts.length > 0 && (
        <section class="section-block">
          <h3 class="section-title">Rascunhos <span class="count">{drafts.length}</span></h3>
          <div class="list">
            {drafts.map((article) => (
              <a class="row" href={`/admin/edit/${article.id}`}>
                <div class="meta-col">
                  <h3>{article.data.title}</h3>
                  <p class="dek">{article.data.dek}</p>
                </div>
                <span class="cat">{categoryLabels[article.data.categories[0]] ?? article.data.categories[0]}</span>
                <span class="date">{fmtDate.format(article.data.date)}</span>
                <span class="badge-draft">Rascunho</span>
              </a>
            ))}
          </div>
        </section>
      )}

      {published.length > 0 && (
        <section class="section-block">
          <h3 class="section-title">Publicados <span class="count">{published.length}</span></h3>
          <div class="list">
            {published.map((article) => (
              <a class="row" href={`/admin/edit/${article.id}`}>
                <div class="meta-col">
                  <h3>{article.data.title}</h3>
                  <p class="dek">{article.data.dek}</p>
                </div>
                <span class="cat">{categoryLabels[article.data.categories[0]] ?? article.data.categories[0]}</span>
                <span class="date">{fmtDate.format(article.data.date)}</span>
                <span class="badge-draft" style="visibility:hidden">·</span>
              </a>
            ))}
          </div>
        </section>
      )}
    </>
  )}

  <p style="margin-top:32px;font-size:13px;color:#888"><a href="/" style="color:#888">← Ver site</a></p>
</body>
</html>
