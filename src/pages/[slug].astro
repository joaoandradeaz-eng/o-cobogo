---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import AuthorInsert from '../components/AuthorInsert.astro';
import { getCollection, render } from 'astro:content';
import '../styles/article.css';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const { data } = article;

// "Continue lendo": até 3 artigos. Prioriza quem compartilha editoria com o atual
// (leitura temática faz mais sentido), e dentro de cada grupo, os mais recentes.
const currentCats = new Set(article.data.categories);
const continueReading = (await getCollection('articles', ({ data }) => !data.draft))
  .filter((a) => a.id !== article.id)
  .sort((a, b) => {
    const aShared = a.data.categories.some((c) => currentCats.has(c)) ? 1 : 0;
    const bShared = b.data.categories.some((c) => currentCats.has(c)) ? 1 : 0;
    if (aShared !== bShared) return bShared - aShared;
    return b.data.date.getTime() - a.data.date.getTime();
  })
  .slice(0, 3);

// Carrega todas as tags da collection — usado pra resolver labels e cores dinamicamente
const allTags = await getCollection('tags');
const tagsBySlug = new Map(allTags.map((t) => [t.id, t.data]));

type TagInfo = { name: string; color: string; textColor: string; piece: string };
function getTagInfo(slug: string): TagInfo {
  const t = tagsBySlug.get(slug);
  if (t) return { name: t.name, color: t.color, textColor: t.textColor, piece: t.piece ?? 'grade' };
  // Fallback se a tag foi deletada mas o artigo ainda a referencia
  return { name: slug, color: '#eee', textColor: '#666', piece: 'grade' };
}

// converte *texto* (markdown emphasis) em <em>texto</em>; usado em campos de frontmatter
function parseInlineMd(text: string): string {
  return text.replace(/\*([^*]+)\*/g, '<em>$1</em>');
}
const titleHtml = parseInlineMd(data.title);
const dekHtml = parseInlineMd(data.dek);
const titlePlain = data.title.replace(/\*/g, '');
const dekPlain = data.dek.replace(/\*/g, '');

// JSON-LD (schema.org Article) — ajuda buscadores e prévia de links.
const articleUrl = new URL(`/${article.id}`, Astro.site).href;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: titlePlain,
  description: dekPlain,
  datePublished: data.date.toISOString(),
  author: { '@type': 'Person', name: data.author.replace(/\*/g, '') },
  publisher: { '@type': 'Organization', name: 'O Cobogó' },
  mainEntityOfPage: articleUrl,
  ...(data.heroImage ? { image: new URL(data.heroImage, Astro.site).href } : {}),
};

// formato data: "12 mar 2026" (UTC pra evitar timezone shift)
const months = ['jan', 'fev', 'mar', 'abr', 'mai', 'jun', 'jul', 'ago', 'set', 'out', 'nov', 'dez'];
const d = data.date;
const dateFmt = `${String(d.getUTCDate()).padStart(2, '0')} ${months[d.getUTCMonth()]} ${d.getUTCFullYear()}`;
// data dos cards "Continue lendo": "11 Mar 2026" (mês capitalizado)
function fmtCardDate(date: Date): string {
  const m = months[date.getUTCMonth()];
  return `${String(date.getUTCDate()).padStart(2, '0')} ${m.charAt(0).toUpperCase()}${m.slice(1)} ${date.getUTCFullYear()}`;
}
---

<BaseLayout
  title={`${titlePlain} · O Cobogó`}
  active="home"
  screenLabel="Artigo"
  description={dekPlain}
  image={data.heroImage}
  type="article"
  showIntro={false}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)}></script>

  <!-- VOLTAR AO TOPO (flutuante, aparece após rolar) -->
  <button class="to-top" type="button" aria-label="Voltar ao topo" hidden>↑</button>

  <!-- ARTICLE HEADER -->
  <header class="art-hd">
    <div class="tags">
      {data.categories.map((cat) => {
        const ti = getTagInfo(cat);
        return (
          <a class="tag-item tag-link" href={`/tags/${cat}`} aria-label={`Ver artigos em ${ti.name}`}>
            <svg class="tag-mark" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet" aria-hidden="true" style={`color:${ti.color}`}><use href={`#cobogo-${ti.piece}`} width="100" height="100" /></svg>
            <span class="tag" data-cat={cat} style={`background:${ti.color};color:${ti.textColor}`}>{ti.name}</span>
          </a>
        );
      })}
    </div>
    <div class="rule"></div>
    <h1 set:html={titleHtml}></h1>
    <p class="dek" set:html={dekHtml}></p>

    <div class="byline">
      <span class="bit byline-author">
        <a href="/sobre" class="by-author">
          <img src="/assets/joao-andrade-48.jpg" alt="" loading="eager" decoding="async" width="24" height="24" />
          por <span set:html={parseInlineMd(data.author)}></span>
        </a>
      </span>
      <span class="sep">·</span>
      <span class="bit">{dateFmt}</span>
      <span class="sep">·</span>
      <span class="bit">{data.readTime}</span>
    </div>
  </header>

  <!-- HERO IMAGE -->
  <div class="art-hero">
    <figure>
      {data.heroImage
        ? <img src={data.heroImage} alt={data.heroCaption ?? ''} style={`object-position:${data.heroPosition ?? '50% 50%'};transform:scale(${data.heroZoom ?? 1});transform-origin:${data.heroPosition ?? '50% 50%'}`} />
        : <div class="ph">imagem · placeholder</div>}
    </figure>
    {data.heroCaption && (
      <figcaption><span>{data.heroCaption}</span></figcaption>
    )}
  </div>

  <!-- BODY -->
  <section class="art-body">

    {data.linhaFina && (
      <aside class="linha-fina">
        {data.linhaFinaLabel !== '' && (
          <div class="label">{data.linhaFinaLabel ?? 'Linha-fina'}</div>
        )}
        <div class="v" set:html={parseInlineMd(data.linhaFina)}></div>
      </aside>
    )}

    <article class="col">
      <Content />
    </article>

    {data.notas && data.notas.length > 0 && (
      <aside class="notas">
        <div class="label">Notas</div>
        <ol>
          {data.notas.map((nota, i) => (
            <li id={`nota-${i + 1}`} set:html={parseInlineMd(nota)} />
          ))}
        </ol>
      </aside>
    )}

    <!-- COMPARTILHAR / ASSINAR -->
    <div class="art-share">
      <span class="art-share-label">Gostou? Compartilhe</span>
      <div class="art-share-actions">
        <button type="button" class="share-btn" data-share>Compartilhar →</button>
        <a class="share-btn" href="/rss.xml">Assinar via RSS</a>
      </div>
    </div>

  </section>

  <!-- INSERT: SOBRE O AUTOR -->
  <AuthorInsert />

  <!-- CONTINUE LENDO -->
  {continueReading.length > 0 && (
  <section class="continue">
    <div class="head">
      <h2>Continue <em>lendo</em></h2>
      <a href="/" class="more">Voltar à edição →</a>
    </div>
    <div class="grid">
      {continueReading.map((a) => (
      <a href={`/${a.id}`}>
        <div class="date">{fmtCardDate(a.data.date)}</div>
        <h3 set:html={parseInlineMd(a.data.title)}></h3>
        <div class="by"><span class="by-author"><img src="/assets/joao-andrade-48.jpg" alt="" loading="lazy" decoding="async" width="24" height="24" />por <span set:html={parseInlineMd(a.data.author)}></span></span></div>
      </a>
      ))}
    </div>
  </section>
  )}

  <script is:inline>
    /* Notas de rodapé: clique no número vai até a nota; ↩ na nota volta ao texto. */
    function flash(el) {
      if (!el) return;
      el.scrollIntoView({ behavior: 'smooth', block: 'center' });
      el.classList.add('nota-flash');
      setTimeout(() => el.classList.remove('nota-flash'), 1800);
    }

    const refByNum = {};
    document.querySelectorAll('.art-body .col sup').forEach((sup) => {
      const num = sup.textContent?.trim();
      if (!num || !/^\d+$/.test(num)) return;
      // 1ª ocorrência do número vira âncora de retorno (#ref-N)
      if (!refByNum[num]) { sup.id = 'ref-' + num; refByNum[num] = sup; }
      sup.style.cursor = 'pointer';
      sup.setAttribute('role', 'link');
      sup.setAttribute('tabindex', '0');
      sup.setAttribute('aria-label', 'Ir para a nota ' + num);
      const go = () => flash(document.getElementById('nota-' + num));
      sup.addEventListener('click', go);
      sup.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); go(); }
      });
    });

    document.querySelectorAll('.art-body .notas li[id^="nota-"]').forEach((li) => {
      const num = li.id.replace('nota-', '');
      if (!refByNum[num]) return; // só adiciona retorno se a nota é citada no texto
      const back = document.createElement('a');
      back.className = 'nota-back';
      back.href = '#ref-' + num;
      back.textContent = '↩';
      back.setAttribute('aria-label', 'Voltar ao texto');
      back.addEventListener('click', (e) => { e.preventDefault(); flash(refByNum[num]); });
      li.appendChild(document.createTextNode(' '));
      li.appendChild(back);
    });
  </script>

  <script is:inline>
    /* Botão "voltar ao topo": aparece depois de rolar, some no topo */
    (function () {
      const toTop = document.querySelector('.to-top');
      if (!toTop) return;
      const root = document.documentElement;
      function onScroll() {
        toTop.hidden = root.scrollTop < 600;
      }
      document.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
      toTop.addEventListener('click', () =>
        window.scrollTo({ top: 0, behavior: 'smooth' })
      );
    })();

    /* Compartilhar: usa o menu nativo do celular (Web Share); no desktop, copia o link */
    (function () {
      const btn = document.querySelector('[data-share]');
      if (!btn) return;
      btn.addEventListener('click', async () => {
        const url = location.href;
        const title = document.title;
        if (navigator.share) {
          try { await navigator.share({ title, url }); } catch (e) {}
        } else {
          try {
            await navigator.clipboard.writeText(url);
            const old = btn.textContent;
            btn.textContent = 'Link copiado ✓';
            setTimeout(() => { btn.textContent = old; }, 1800);
          } catch (e) {}
        }
      });
    })();
  </script>

</BaseLayout>
