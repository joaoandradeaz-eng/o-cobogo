---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import AuthorInsert from '../components/AuthorInsert.astro';
import { getCollection, render } from 'astro:content';
import '../styles/article.css';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const { data } = article;

// labels visíveis das categorias (chave em kebab-case → label em português)
const categoryLabels: Record<string, string> = {
  'ensaio': 'Ensaio',
  'reportagem': 'Reportagem',
  'critica': 'Crítica',
  'entrevista': 'Entrevista',
  'memoria': 'Memória',
  'cidade-casa': 'Cidade & Casa',
};

// converte *texto* (markdown emphasis) em <em>texto</em>; usado em campos de frontmatter
function parseInlineMd(text: string): string {
  return text.replace(/\*([^*]+)\*/g, '<em>$1</em>');
}
const titleHtml = parseInlineMd(data.title);
const dekHtml = parseInlineMd(data.dek);
const titlePlain = data.title.replace(/\*/g, '');

// formato data: "12 mar 2026" (UTC pra evitar timezone shift)
const months = ['jan', 'fev', 'mar', 'abr', 'mai', 'jun', 'jul', 'ago', 'set', 'out', 'nov', 'dez'];
const d = data.date;
const dateFmt = `${String(d.getUTCDate()).padStart(2, '0')} ${months[d.getUTCMonth()]} ${d.getUTCFullYear()}`;
---

<BaseLayout title={`${titlePlain} · O Cobogó`} active="home" screenLabel="Artigo">

  <!-- ARTICLE HEADER -->
  <header class="art-hd">
    <div class="tags">
      {data.categories.map((cat) => (
        <span class="tag" data-cat={cat}>{categoryLabels[cat] ?? cat}</span>
      ))}
    </div>
    <div class="rule"></div>
    <h1 set:html={titleHtml}></h1>
    <p class="dek" set:html={dekHtml}></p>

    <div class="byline">
      <span class="bit byline-author">
        <a href="/sobre" class="by-author">
          <img src="/assets/joao-andrade-48.jpg" alt="" loading="eager" decoding="async" width="24" height="24" />
          por <span set:html={parseInlineMd(data.author)}></span>
        </a>
      </span>
      <span class="sep">·</span>
      <span class="bit">{dateFmt}</span>
      <span class="sep">·</span>
      <span class="bit">{data.readTime}</span>
    </div>
  </header>

  <!-- HERO IMAGE -->
  <div class="art-hero">
    <figure>
      {data.heroImage
        ? <img src={data.heroImage} alt={data.heroCaption ?? ''} />
        : <div class="ph">imagem · placeholder</div>}
    </figure>
    {data.heroCaption && (
      <figcaption><span>{data.heroCaption}</span></figcaption>
    )}
  </div>

  <!-- BODY -->
  <section class="art-body">

    {data.linhaFina && (
      <aside class="linha-fina">
        {data.linhaFinaLabel !== '' && (
          <div class="label">{data.linhaFinaLabel ?? 'Linha-fina'}</div>
        )}
        <div class="v" set:html={parseInlineMd(data.linhaFina)}></div>
      </aside>
    )}

    <article class="col">
      <Content />
    </article>

    {data.notas && data.notas.length > 0 && (
      <aside class="notas">
        <div class="label">Notas</div>
        <ol>
          {data.notas.map((nota, i) => (
            <li id={`nota-${i + 1}`} set:html={parseInlineMd(nota)} />
          ))}
        </ol>
      </aside>
    )}

  </section>

  <!-- INSERT: SOBRE O AUTOR -->
  <AuthorInsert />

  <!-- CONTINUE LENDO (estático enquanto não temos múltiplos artigos) -->
  <section class="continue">
    <div class="head">
      <h2>Continue <em>lendo</em></h2>
      <a href="/" class="more">Voltar à edição →</a>
    </div>
    <div class="grid">
      <a href="#">
        <div class="date">11 Mar 2026</div>
        <h3>A democracia local não cabe nas plataformas — e talvez seja melhor assim</h3>
        <div class="by"><span class="by-author"><img src="/assets/joao-andrade-48.jpg" alt="" loading="lazy" decoding="async" width="24" height="24" />por <span>João Andrade</span></span></div>
      </a>
      <a href="#">
        <div class="date">04 Mar 2026</div>
        <h3>Tradução é uma forma de hospitalidade — e está <em>desgastada</em></h3>
        <div class="by"><span class="by-author"><img src="/assets/joao-andrade-48.jpg" alt="" loading="lazy" decoding="async" width="24" height="24" />por <span>João Andrade</span></span></div>
      </a>
      <a href="#">
        <div class="date">19 Fev 2026</div>
        <h3>Onde mora o ruído: um ano ouvindo a Avenida Conde da <em>Boa Vista</em></h3>
        <div class="by"><span class="by-author"><img src="/assets/joao-andrade-48.jpg" alt="" loading="lazy" decoding="async" width="24" height="24" />por <span>João Andrade</span></span></div>
      </a>
    </div>
  </section>

  <script is:inline>
    /* Footnote anchors: sup no corpo → scroll suave até #nota-N */
    document.querySelectorAll('.art-body .col sup').forEach((sup) => {
      const num = sup.textContent?.trim();
      if (!num || !/^\d+$/.test(num)) return;
      sup.style.cursor = 'pointer';
      sup.setAttribute('role', 'link');
      sup.setAttribute('tabindex', '0');
      const go = () => {
        const target = document.getElementById('nota-' + num);
        if (!target) return;
        target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        target.classList.add('nota-flash');
        setTimeout(() => target.classList.remove('nota-flash'), 1800);
      };
      sup.addEventListener('click', go);
      sup.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); go(); }
      });
    });
  </script>

</BaseLayout>
